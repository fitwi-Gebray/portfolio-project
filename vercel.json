{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "booking-app/dist/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/server.js" },
    { "handle": "filesystem" },
    { "src": "/assets/(.*)", "dest": "booking-app/dist/assets/$1" },
    { "src": "/(.*)", "dest": "booking-app/dist/index.html" }
  ]
}
