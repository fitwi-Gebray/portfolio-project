{
  "version": 2,
  "builds": [{ "src": "api/server.js", "use": "@vercel/node" }],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/server.js" },
    { "source": "/assets/(.*)", "destination": "booking-app/dist/assets/$1" },
    { "source": "/(.*)", "destination": "booking-app/dist/index.html" }
  ]
}
