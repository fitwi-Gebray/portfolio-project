{
  "version": 2,
  "builds": [
    {
      "src": "booking-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "cd booking-app && npm run build"
      }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "booking-app/dist/index.html" }
  ]
}
